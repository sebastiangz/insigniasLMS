# ─── listening ────────────────────────────────────────────
PORT=3001

# ─── public base URL (NO trailing slash) ──────────────────
# Este es el dominio que aparece en los JSON de Open Badges.
# Debe ser accesible desde Internet para que Moodle verifique las assertions.
PUBLIC_URL=https://backpack.dominio

# ─── SQLite (archivo local, sin servidor externo) ─────────
DB_PATH=./data/backpack.db

# ─── OAuth 2 / JWT ────────────────────────────────────────
# Secreto largo y aleatorio. Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CAMBIAR_ESTO_POR_UN_VALOR_ALEATORIO_LARGO

# Vida útil del access_token (segundos). Moodle espera ≤3600.
ACCESS_TOKEN_TTL=3600

# Vida útil del refresh_token (segundos). 30 días.
REFRESH_TOKEN_TTL=2592000

# ─── Dynamic Client Registration ──────────────────────────
# Si está en "true", cualquier Consumer puede registrarse automáticamente
# (recomendado para desarrollo; en producción pon "false" y registra a Moodle manualmente).
ALLOW_DYNAMIC_REGISTRATION=true

# ─── CORS ──────────────────────────────────────────────────
# URL de tu Moodle (sin trailing slash).  El backpack permite origen cruzado solo desde aquí.
MOODLE_ORIGIN=https://educacioncontinua.ucol.mx
